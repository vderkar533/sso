@page "/auth/reset-password"
@model SSO.Server.Pages.Auth.ResetPasswordModel

<h2>Reset Password</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert">@Model.Message</div>
}
@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="error">@Model.Error</div>
}

<form method="post">
    <label>Email</label>
    <input type="email" asp-for="Email" required />

    <label>Token</label>
    <input type="text" asp-for="Token" required />

    <label>New Password</label>
    <input type="password" asp-for="NewPassword" required />

    <button type="submit">Reset Password</button>
</form>
