@page "/auth/logout"
@model SSO.Server.Pages.Auth.LogoutModel

<h2>Logout</h2>
<p class="muted">Paste the refresh token to revoke the session server-side.</p>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert">@Model.Message</div>
}
@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="error">@Model.Error</div>
}

<form method="post">
    <label>Refresh Token</label>
    <input type="text" asp-for="RefreshToken" required />

    <button type="submit">Logout</button>
</form>

<div class="muted" style="margin-top: 12px;">
    If your client stores tokens locally, you can clear them here:
</div>
<button type="button" id="clearTokensBtn">Clear Local Tokens</button>

<script>
    (function () {
        var btn = document.getElementById("clearTokensBtn");
        if (!btn) return;
        btn.addEventListener("click", function () {
            var keys = ["accessToken", "refreshToken", "token", "idToken"];
            keys.forEach(function (k) {
                localStorage.removeItem(k);
                sessionStorage.removeItem(k);
            });
            alert("Local tokens cleared from this browser.");
        });
    })();
</script>
