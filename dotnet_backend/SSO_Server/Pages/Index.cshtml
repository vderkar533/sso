@page
@model SSO.Server.Pages.IndexModel

<section class="hero">
    <div>
        <h2>Single Sign-On Hub</h2>
        <p class="muted">Manage identity flows, protect internal applications, and keep sign-ins consistent across teams.</p>
        <div class="hero-actions">
            <a class="cta primary" href="/auth/login">Login</a>
            <a class="cta ghost" href="/auth/register">Register</a>
        </div>
        <p class="muted small">For employees and authorized partners only.</p>
    </div>
</section>

<style>
    .hero {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        align-items: center;
        margin-bottom: 26px;
    }

    .hero h2 { font-size: 32px; }
    .hero p { margin: 8px 0 16px; }
    .hero .small { font-size: 12px; }

    .hero-actions {
        display: flex;
        gap: 12px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 600;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .cta.primary {
        background: var(--accent);
        color: #ffffff;
        box-shadow: 0 12px 24px rgba(220, 38, 38, 0.28);
    }

    .cta.ghost {
        border: 1px solid var(--line);
        color: var(--ink);
        background: transparent;
    }

    .cta:hover { transform: translateY(-1px); }

    @@media (max-width: 720px) {
        .hero { grid-template-columns: 1fr; }
    }
</style>
